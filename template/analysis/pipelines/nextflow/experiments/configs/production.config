// Production Configuration
// Optimized for reliability and performance

// Import base configuration
includeConfig 'base.config'

// Higher resource defaults for production
process {
    cpus = 4
    memory = '16.GB'
    time = '24.h'
    
    errorStrategy = 'retry'
    maxRetries = 3
    maxErrors = '-1'  // Continue despite errors
}

// Production-specific parameters
params {
    max_cpus = 32
    max_memory = '256.GB'
    max_time = '168.h'  // 7 days
    
    // Full datasets
    dev_mode = false
    
    // Cost tracking
    enable_cost_tracking = true
}

// Cleanup work directory after successful run
cleanup = true
