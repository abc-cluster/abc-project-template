// Development Configuration
// Optimized for faster feedback and local testing

// Import base configuration
includeConfig 'base.config'

// Lower resource defaults for development
process {
    cpus = 1
    memory = '2.GB'
    time = '2.h'
    
    errorStrategy = 'finish'  // Fail fast for development
    maxRetries = 1
}

// Executor settings for development
executor {
    name = 'local'
    cpus = 4
    memory = '16.GB'
}

// Development-specific parameters
params {
    max_cpus = 4
    max_memory = '16.GB'
    max_time = '6.h'
    
    // Smaller datasets for testing
    sample_size = 100
    dev_mode = true
}

// Cleanup work directory after successful run
cleanup = false  // Keep for debugging
