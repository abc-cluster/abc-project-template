// nextflow.config — abc-project-template nextflow configuration
//
// Profiles:
//   abc_nomad  — ABC-cluster Nomad executor with s5cmd S3 workdir (default for ABC-cluster)
//   tower      — Seqera Tower / Platform monitoring with AWS Batch
//   local      — Local executor (development / laptop)
//   slurm      — SLURM executor (HPC cluster without ABC-cluster)
//
// Usage:
//   nextflow run <pipeline>.nf -profile abc_nomad    # ABC-cluster
//   nextflow run <pipeline>.nf -profile tower        # Seqera Tower
//   nextflow run <pipeline>.nf -profile local        # local development

// Default parameters
params {
    outdir         = './results'
    tracedir       = "${params.outdir}/pipeline_info"
    max_cpus       = 16
    max_memory     = '64.GB'
    max_time       = '24.h'
}

profiles {

    // ─── ABC-cluster / Nomad ──────────────────────────────────────────────────
    //
    // Requires:
    //   ABC_HOST   — ABC-cluster host (e.g. seedling.abc-cluster.cloud)
    //   ABC_TOKEN  — bearer token from `abc auth login`
    //
    // Optional:
    //   ABC_PROJECT      — project ID to tag this investigation run
    //   ABC_MINIO_ENDPOINT — MinIO endpoint for workdir (default: https://<ABC_HOST>:9000)
    //   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY — MinIO credentials (injected by `abc run`)
    //
    abc_nomad {
        plugins {
            id 'nf-nomad'
        }

        nomad {
            client {
                address = "https://${System.getenv('ABC_HOST') ?: 'localhost'}:4646"
                token   = System.getenv('ABC_TOKEN')
                tls {
                    ca_cert = '/etc/nomad.d/tls/ca.pem'    // path inside container
                }
            }
        }

        process {
            executor = 'nomad'

            // Default container — override per-process with `container` directive
            container = 'ubuntu:22.04'

            // Resource defaults — nf-nomad maps these to Nomad task resources
            cpus   = { check_max( 2 * task.attempt, 'cpus' ) }
            memory = { check_max( 4.GB * task.attempt, 'memory' ) }
            time   = { check_max( 4.h * task.attempt, 'time' ) }

            errorStrategy = { task.exitStatus in [104,134,137,139,143,247] ? 'retry' : 'terminate' }
            maxRetries    = 2
        }

        // s5cmd-based S3 workdir (nf-nomad-s5cmd plugin convention)
        // ABC-cluster injects AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY for the
        // user's MinIO bucket. Set ABC_MINIO_ENDPOINT to override the endpoint.
        workDir = "s3://${System.getenv('ABC_PROJECT') ?: 'project'}/nxf-work"

        aws {
            accessKey = System.getenv('AWS_ACCESS_KEY_ID')
            secretKey = System.getenv('AWS_SECRET_ACCESS_KEY')
            client {
                endpoint    = System.getenv('ABC_MINIO_ENDPOINT') ?: "https://${System.getenv('ABC_HOST') ?: 'localhost'}:9000"
                s3PathStyleAccess = true
                // Disable SSL verification for private CA (abc-seedling uses self-signed cert)
                // Set ABC_MINIO_USE_TLS=true if your cluster uses a trusted CA
                protocol    = (System.getenv('ABC_MINIO_USE_TLS') == 'true') ? 'HTTPS' : 'HTTP'
            }
        }

        // Tag runs with project and investigation metadata
        params {
            abc_host      = System.getenv('ABC_HOST')
            abc_project   = System.getenv('ABC_PROJECT')
        }
    }

    // ─── Seqera Tower / Platform ─────────────────────────────────────────────
    //
    // Requires:
    //   TOWER_ACCESS_TOKEN  — from Seqera Tower / Platform
    //   TOWER_WORKSPACE_ID  — workspace ID
    //
    tower {
        tower {
            enabled     = true
            accessToken = System.getenv('TOWER_ACCESS_TOKEN')
            workspaceId = System.getenv('TOWER_WORKSPACE_ID')
            endpoint    = System.getenv('TOWER_ENDPOINT') ?: 'https://tower.nf'
        }

        process {
            executor = 'awsbatch'
            queue    = System.getenv('AWS_BATCH_QUEUE') ?: 'default'
            cpus     = { check_max( 2 * task.attempt, 'cpus' ) }
            memory   = { check_max( 4.GB * task.attempt, 'memory' ) }
            time     = { check_max( 4.h * task.attempt, 'time' ) }

            errorStrategy = { task.exitStatus in [104,134,137,139,143,247] ? 'retry' : 'terminate' }
            maxRetries    = 2
        }

        workDir = "s3://${System.getenv('AWS_S3_BUCKET') ?: 'my-bucket'}/nxf-work"

        aws {
            region = System.getenv('AWS_REGION') ?: 'us-east-1'
        }
    }

    // ─── Local (development / laptop) ────────────────────────────────────────
    local {
        process {
            executor = 'local'
            cpus     = { check_max( 4, 'cpus' ) }
            memory   = { check_max( 8.GB * task.attempt, 'memory' ) }
            time     = { check_max( 4.h * task.attempt, 'time' ) }
        }

        workDir = './work'

        docker {
            enabled     = false
            userEmulation = true
        }
    }

    // ─── SLURM (HPC without ABC-cluster) ─────────────────────────────────────
    slurm {
        process {
            executor   = 'slurm'
            queue      = System.getenv('SLURM_PARTITION') ?: 'compute'
            cpus       = { check_max( 4 * task.attempt, 'cpus' ) }
            memory     = { check_max( 8.GB * task.attempt, 'memory' ) }
            time       = { check_max( 8.h * task.attempt, 'time' ) }
            clusterOptions = "--account=${System.getenv('SLURM_ACCOUNT') ?: ''}"

            errorStrategy = { task.exitStatus in [104,134,137,139,143,247] ? 'retry' : 'terminate' }
            maxRetries    = 2
        }

        workDir = './work'

        singularity {
            enabled  = true
            autoMounts = true
            cacheDir = "${HOME}/.singularity/cache"
        }
    }
}

// ─── Shared error handling helper ────────────────────────────────────────────
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid. Using: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid. Using: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid. Using: $obj"
            return obj
        }
    }
}
