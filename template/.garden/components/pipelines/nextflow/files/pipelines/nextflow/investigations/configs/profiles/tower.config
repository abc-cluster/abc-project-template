// Tower Profile
// For pipelines launched via Seqera Platform (Tower)
// Compute environment is managed by Tower

// Minimal configuration - Tower manages compute environment
tower {
    enabled = true
}

// Let Tower handle most configuration
// Work directory and output directory set via Tower launch

params {
    // Tower-specific settings
    tower_workspace = System.getenv('TOWER_WORKSPACE_ID') ?: 'default'
}

// Reports still generated
report {
    enabled = true
    file = "${params.outdir}/reports/execution_report.html"
}

timeline {
    enabled = true
    file = "${params.outdir}/reports/timeline.html"
}

trace {
    enabled = true
    file = "${params.outdir}/reports/trace.txt"
}