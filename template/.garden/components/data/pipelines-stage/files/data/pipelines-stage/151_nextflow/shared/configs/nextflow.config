// Nextflow configuration for single research project
// Optimized for academic research workflows

// Global configuration
workDir = "15_pipelines/151_nextflow/experiments/by_analysis/*/work"
process.cache = 'lenient'

// Resource profiles for different computing environments
profiles {
    standard {
        process {
            cpus = 2
            memory = '4 GB'
            time = '2h'
        }
    }
    
    high_mem {
        process {
            cpus = 4
            memory = '16 GB'
            time = '4h'
        }
    }
    
    cluster {
        process {
            executor = 'slurm'
            queue = 'research'
            cpus = 8
            memory = '16 GB'
            time = '8h'
        }
    }
    
    local {
        process {
            executor = 'local'
            cpus = 1
            memory = '2 GB'
        }
    }
}

// Process-specific configurations
process {
    withLabel: 'high_memory' {
        memory = '32 GB'
        cpus = 16
    }
    
    withLabel: 'long_running' {
        time = '24h'
    }
    
    withLabel: 'fast' {
        cpus = 1
        memory = '1 GB'
        time = '30m'
    }
    
    // Default publishing strategy
    publishDir = [
        path: "${params.outdir}",
        mode: 'copy',
        saveAs: { filename ->
            if (filename.endsWith('.log')) "logs/$filename"
            else if (filename.endsWith('.html')) "reports/$filename"  
            else if (filename.endsWith('.yaml') || filename.endsWith('.yml')) "metadata/$filename"
            else "outputs/$filename"
        }
    ]
}

// Error handling
process.errorStrategy = 'retry'
process.maxRetries = 2

// Reporting configuration
report {
    enabled = true
    file = "${params.outdir}/../logs/report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/../logs/trace.txt"
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem'
}

timeline {
    enabled = true
    file = "${params.outdir}/../logs/timeline.html"
}

dag {
    enabled = true
    file = "${params.outdir}/../logs/dag.html"
}

// Manifest for academic workflows
manifest {
    name = 'academic-research-pipeline'
    author = 'Research Team'
    description = 'Single project academic research data processing'
    version = '1.0.0'
    nextflowVersion = '>=21.0.0'
}
